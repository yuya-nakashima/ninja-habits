{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist-api",
    "rootDir": "api"
  },
  "include": ["api/**/*.ts"],
  "exclude": ["api/**/*.test.ts"]
}
