{
  "name": "ninja-habits",
  "private": true,
  "type": "module",
  "scripts": {
    "api:build": "tsc -p tsconfig.api.json",
    "api:dev": "tsx watch api/server.ts",
    "api:migrate": "tsx api/migrate.ts",
    "api:start": "node dist-api/server.js",
    "dev": "vite",
    "build": "tsc -b && tsc -p tsconfig.api.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
