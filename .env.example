VITE_API_BASE_URL=http://localhost:8080
VITE_DEV_AUTH=true
VITE_DEV_AUTH_EMAIL=local@example.com
VITE_DEV_AUTH_SUB=local-user
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_DOMAIN=https://ninja-habits-dev.auth.ap-northeast-1.amazoncognito.com
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/
VITE_COGNITO_LOGOUT_URI=http://localhost:5173/

PORT=8080
DATABASE_URL=postgresql://ninja:ninja@127.0.0.1:15432/ninja_habits
API_ALLOWED_ORIGIN=http://127.0.0.1:5173
# 実 Cognito 検証時は API_DEV_AUTH を外す（true だと dev ヘッダ認証になる）
API_DEV_AUTH=true
# COGNITO_ISSUER を直接指定するか、AWS_REGION + COGNITO_USER_POOL_ID で組み立てる
AWS_REGION=ap-northeast-1
COGNITO_USER_POOL_ID=
# ID トークンの aud を照合する期待クライアントID（未設定だと aud 検証をスキップ）
COGNITO_CLIENT_ID=
